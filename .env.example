# ============================================
# EJEMPLO DE VARIABLES DE ENTORNO
# Copia este archivo a .env y configura tus valores
# ============================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=teacher_assistant_db

# Flask Backend
SECRET_KEY=dev-secret-key-change-in-production
FLASK_ENV=development

# Telegram Bot
TELEGRAM_BOT_TOKEN=tu_token_de_telegram_aqui

# Gemini AI
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# CORS Origins (separados por coma)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:80

# Firebase Backend (coloca el archivo JSON de service account en backend/)
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# Firebase Frontend (para autenticación en el navegador)
# Obtener de: https://console.firebase.google.com/ → Project Settings → Your apps
VITE_FIREBASE_API_KEY=tu_firebase_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto-id
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456
